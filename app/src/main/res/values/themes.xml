<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.MacQuery" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/color_gold</item>
        <item name="colorPrimaryDark">@color/color_background</item>
        <item name="colorOnPrimary">@color/color_background</item>
        <item name="colorSecondary">@color/color_gold_soft</item>
        <item name="colorOnSecondary">@color/color_background</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorOnSurface">@color/color_cream</item>
        <item name="android:colorBackground">@color/color_background</item>

        <item name="android:statusBarColor">@color/color_background</item>
        <item name="android:navigationBarColor">@color/color_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>

    <style name="Theme.MacQuery.Splash" parent="Theme.MacQuery">
        <item name="android:windowBackground">@drawable/bg_splash</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>

</resources>
